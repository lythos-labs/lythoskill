# Dependencies
node_modules/

# OS
.DS_Store

# Logs
*.log

# Build output (legacy, now skills/ is the build target)
dist/

# Runtime config (project-local, generated by init)
.project-workflow.json

# Task ID database (if using incremental ID mode)
.task-id-db.json

# npm access token (local-only, never commit)
.npm-access

# GitHub access token (local-only, never commit)
.github-token

playground/
.claude/

# Private operational docs (local-only, never commit)
.private/

# Runtime lock file (contains absolute local paths, not portable)
skill-deck.lock

# Curator generated artifacts (cold pool index, regenerated at runtime)
skills/.lythoskill-curator/

# Temporary directories and files
tmp/
.tmp/
conversation-boost.txt

.husky/_
