#!/bin/sh
# Pre-commit: ADR compliance + auto-rebuild skills + cortex governance (TypeScript)

# 1. ADR governance checks (fast — fail early if violated)
if [ -f scripts/adr-check.sh ]; then
  bash scripts/adr-check.sh || exit 1
fi

# 2. Auto-rebuild skills when source files change in packages/**/skill/
STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep '^packages/.*/skill/' || true)

if [ -n "$STAGED" ]; then
  echo "🛠️  Skill source files changed, rebuilding all skills..."
  bun packages/lythoskill-creator/src/cli.ts build --all

  # Stage built output so skills/ stays in sync with packages/**/skill/
  git add skills/
  echo "✅ Skills rebuilt and staged"
fi

# 3. Cortex governance: Epic-ADR coupling + lane guard + in-progress reminder (TypeScript)
#    → delegates to packages/lythoskill-project-cortex/src/hooks/pre-commit.ts (T2+T3)
bun packages/lythoskill-project-cortex/src/hooks/pre-commit.ts

# 4. Test gate: run tests for changed packages, block if any fail ("测试必须 0 fail")
bun scripts/pre-commit-test.ts || exit 1
