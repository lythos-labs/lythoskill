#!/bin/sh
# Pre-commit: ADR compliance checks + auto-rebuild skills

# 1. ADR governance checks (fast — fail early if violated)
if [ -f scripts/adr-check.sh ]; then
  bash scripts/adr-check.sh || exit 1
fi

# 2. Auto-rebuild skills when source files change in packages/**/skill/
STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep '^packages/.*/skill/' || true)

if [ -n "$STAGED" ]; then
  echo "🛠️  Skill source files changed, rebuilding all skills..."
  bun packages/lythoskill-creator/src/cli.ts build --all

  # Stage built output so skills/ stays in sync with packages/**/skill/
  git add skills/
  echo "✅ Skills rebuilt and staged"
fi

# 3. Epic-ADR coupling guard: auto-accept ADR when its epic is staged
STAGED_EPICS=$(git diff --cached --name-only --diff-filter=A | grep '^cortex/epics/01-active/EPIC-' || true)
if [ -n "$STAGED_EPICS" ]; then
  for epic_file in $STAGED_EPICS; do
    epic_id=$(basename "$epic_file" | sed -E 's/^(EPIC-[0-9]+)-.*/\1/')
    for adr_file in cortex/adr/01-proposed/ADR-*.md; do
      [ -f "$adr_file" ] || continue
      if grep -q "Epic: $epic_id" "$adr_file"; then
        adr_id=$(basename "$adr_file" | sed -E 's/^(ADR-[0-9]+)-.*/\1/')
        echo "🔗 Auto-accepting $adr_id (linked to $epic_id)"
        bun packages/lythoskill-project-cortex/src/cli.ts adr accept "$adr_id"
      fi
    done
  done
  # Stage any ADR moves produced by the accept commands
  git add cortex/adr/ cortex/INDEX.md cortex/wiki/INDEX.md 2>/dev/null
fi

# 4. Soft reminder for in-progress tasks (no blocker)
IN_PROGRESS_DIR="cortex/tasks/02-in-progress"
count=0
ids=""
for f in "$IN_PROGRESS_DIR"/*.md; do
  [ -f "$f" ] || continue
  count=$((count + 1))
  id=$(basename "$f" | sed -E 's/^([A-Z]+-[0-9]+)-.*/\1/')
  ids="${ids}${id}, "
done

if [ "$count" -gt 0 ]; then
  ids="${ids%, }"
  echo ""
  echo "💡 你有 ${count} 张 in-progress task,如果本次 commit 完成了某张,在 message 末尾加 trailer:"
  echo "     Closes: TASK-<id>"
  echo "   或 Task: TASK-<id> review/done"
  echo "   当前 in-progress: ${ids}"
fi
