# ============================================================
# Skill Deck — Project Skill Declaration
# ============================================================
# Declares which skills are active for this project.
# Undeclared skills are invisible to the agent (deny-by-default).
#
# This file only affects AI context. Zero runtime impact.
# If you don't use AI coding agents, safely ignore this file.
#
# Docs: ask your AI "what is skill-deck.toml?" or see
# lythoskill-deck's references/toml-format.md
# ============================================================
[deck]
working_set = ".claude/skills"        # Agent scans here (symlinks only)
cold_pool   = "~/.agents/skill-repos" # All downloaded skills (agent can't see)
max_cards   = 10                      # Hard limit. Link refuses if exceeded.
# Always-active. Loads every session. Keep few and thin.
# Same-niche skills here cause silent blend — never do this.
[innate]
skills = []

# On-demand. Description always in context; full content loads when relevant.
[tool]
skills = []

# Router skills. One niche slot, delegates to specialists by condition.
[combo]
skills = []

# Temporary workarounds. Must set expires. Shrink and remove over time.
[transient]
# [transient.fix-encoding]
# path = ".claude/skills/_fix-encoding"
# expires = "2026-05-01"
